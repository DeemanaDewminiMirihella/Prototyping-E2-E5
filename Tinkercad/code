#define LEFT_IR 2
#define RIGHT_IR 3

#define LEFT_TRIG 8
#define LEFT_ECHO 9
#define RIGHT_TRIG 4
#define RIGHT_ECHO 7

#define RIGHT_EN 5
#define RIGHT_IN1 10
#define RIGHT_IN2 11

#define LEFT_EN 6
#define LEFT_IN3 12
#define LEFT_IN4 13

#define BLACK HIGH
#define WHITE LOW
// Class: LeftIRSensor
class LeftIRSensor {
  private:
    int pin;

  public:
    LeftIRSensor(int sensorPin) {
      pin = sensorPin;
    }

    void begin() {
      pinMode(pin, INPUT);
    }

    bool detectsBlackLine() {
      return digitalRead(pin) == BLACK;
    }
};
// Class: RightIRSensor
class RightIRSensor {
  private:
    int pin;

  public:
    RightIRSensor(int sensorPin) {
      pin = sensorPin;
    }

    void begin() {
      pinMode(pin, INPUT);
    }

    bool detectsBlackLine() {
      return digitalRead(pin) == BLACK;
    }
};
// Class: LeftUltrasonicSensor
class LeftUltrasonicSensor {
  private:
    int trigPin;
    int echoPin;

  public:
    LeftUltrasonicSensor(int trig, int echo) {
      trigPin = trig;
      echoPin = echo;
    }

    void begin() {
      pinMode(trigPin, OUTPUT);
      pinMode(echoPin, INPUT);
    }

    long getDistanceCM() {
      digitalWrite(trigPin, LOW);
      delayMicroseconds(2);
      digitalWrite(trigPin, HIGH);
      delayMicroseconds(10);
      digitalWrite(trigPin, LOW);

      long duration = pulseIn(echoPin, HIGH, 25000);

      if (duration == 0) {
        return -1;
      }

      return duration * 0.034 / 2;
    }
};
// Class: RightUltrasonicSensor
class RightUltrasonicSensor {
  private:
    int trigPin;
    int echoPin;

  public:
    RightUltrasonicSensor(int trig, int echo) {
      trigPin = trig;
      echoPin = echo;
    }

    void begin() {
      pinMode(trigPin, OUTPUT);
      pinMode(echoPin, INPUT);
    }

    long getDistanceCM() {
      digitalWrite(trigPin, LOW);
      delayMicroseconds(2);
      digitalWrite(trigPin, HIGH);
      delayMicroseconds(10);
      digitalWrite(trigPin, LOW);

      long duration = pulseIn(echoPin, HIGH, 25000);

      if (duration == 0) {
        return -1;
      }

      return duration * 0.034 / 2;
    }
};
// Class: MotorController
class MotorController {
  private:
    int enRight, in1, in2;
    int enLeft, in3, in4;

  public:
    MotorController(int rightEnable, int rightIn1, int rightIn2,
                    int leftEnable, int leftIn3, int leftIn4) {
      enRight = rightEnable;
      in1 = rightIn1;
      in2 = rightIn2;
      enLeft = leftEnable;
      in3 = leftIn3;
      in4 = leftIn4;
    }

    void begin() {
      pinMode(enRight, OUTPUT);
      pinMode(in1, OUTPUT);
      pinMode(in2, OUTPUT);
      pinMode(enLeft, OUTPUT);
      pinMode(in3, OUTPUT);
      pinMode(in4, OUTPUT);
    }

    void moveForward(int speedValue) {
      analogWrite(enRight, speedValue);
      analogWrite(enLeft, speedValue);

      digitalWrite(in1, HIGH);
      digitalWrite(in2, LOW);
      digitalWrite(in3, HIGH);
      digitalWrite(in4, LOW);
    }

    void moveBackward(int speedValue) {
      analogWrite(enRight, speedValue);
      analogWrite(enLeft, speedValue);

      digitalWrite(in1, LOW);
      digitalWrite(in2, HIGH);
      digitalWrite(in3, LOW);
      digitalWrite(in4, HIGH);
    }

    void turnLeft(int speedValue) {
      analogWrite(enRight, speedValue);
      analogWrite(enLeft, speedValue);

      digitalWrite(in1, HIGH);
      digitalWrite(in2, LOW);
      digitalWrite(in3, LOW);
      digitalWrite(in4, HIGH);
    }

    void turnRight(int speedValue) {
      analogWrite(enRight, speedValue);
      analogWrite(enLeft, speedValue);

      digitalWrite(in1, LOW);
      digitalWrite(in2, HIGH);
      digitalWrite(in3, HIGH);
      digitalWrite(in4, LOW);
    }

    void stop() {
      analogWrite(enRight, 0);
      analogWrite(enLeft, 0);

      digitalWrite(in1, LOW);
      digitalWrite(in2, LOW);
      digitalWrite(in3, LOW);
      digitalWrite(in4, LOW);
    }
};
// Class: LineFollowingRobot
class LineFollowingRobot {
  private:
    LeftIRSensor leftIR;
    RightIRSensor rightIR;
    LeftUltrasonicSensor leftUltrasonic;
    RightUltrasonicSensor rightUltrasonic;
    MotorController motorController;

    int baseSpeed;
    int turnSpeed;
    int obstacleDistance;

  public:
    LineFollowingRobot() :
      leftIR(LEFT_IR),
      rightIR(RIGHT_IR),
      leftUltrasonic(LEFT_TRIG, LEFT_ECHO),
      rightUltrasonic(RIGHT_TRIG, RIGHT_ECHO),
      motorController(RIGHT_EN, RIGHT_IN1, RIGHT_IN2, LEFT_EN, LEFT_IN3, LEFT_IN4)
    {
      baseSpeed = 220;
      turnSpeed = 180;
      obstacleDistance = 15;
    }

    void begin() {
      leftIR.begin();
      rightIR.begin();
      leftUltrasonic.begin();
      rightUltrasonic.begin();
      motorController.begin();

      Serial.begin(9600);
    }

    void update() {
      bool leftBlack = leftIR.detectsBlackLine();
      bool rightBlack = rightIR.detectsBlackLine();

      long leftDistance = leftUltrasonic.getDistanceCM();
      long rightDistance = rightUltrasonic.getDistanceCM();

      Serial.print("Left IR: ");
      Serial.print(leftBlack ? "BLACK" : "WHITE");

      Serial.print(" | Right IR: ");
      Serial.print(rightBlack ? "BLACK" : "WHITE");

      Serial.print(" | Left US: ");
      Serial.print(leftDistance);
      Serial.print(" cm");

      Serial.print(" | Right US: ");
      Serial.print(rightDistance);
      Serial.println(" cm");

      if (leftDistance > 0 && leftDistance < obstacleDistance) {
        avoidObstacleLeft();
      }
      else if (rightDistance > 0 && rightDistance < obstacleDistance) {
        avoidObstacleRight();
      }
      else {
        followLine(leftBlack, rightBlack);
      }
    }

    void followLine(bool leftBlack, bool rightBlack) {
      if (leftBlack && rightBlack) {
        motorController.moveForward(baseSpeed);
      }
      else if (leftBlack && !rightBlack) {
        motorController.turnLeft(turnSpeed);
      }
      else if (!leftBlack && rightBlack) {
        motorController.turnRight(turnSpeed);
      }
      else {
        motorController.stop();
      }
    }

    void avoidObstacleLeft() {
      motorController.stop();
      delay(200);
      motorController.moveBackward(baseSpeed);
      delay(300);
      motorController.turnRight(turnSpeed);
      delay(500);
      motorController.stop();
    }

    void avoidObstacleRight() {
      motorController.stop();
      delay(200);
      motorController.moveBackward(baseSpeed);
      delay(300);
      motorController.turnLeft(turnSpeed);
      delay(500);
      motorController.stop();
    }
};

LineFollowingRobot robot;

void setup() {
  robot.begin();
}

void loop() {
  robot.update();
  delay(100);
}
