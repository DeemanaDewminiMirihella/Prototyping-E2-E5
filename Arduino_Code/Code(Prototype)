#define LEFT_IR 3
#define RIGHT_IR 2

#define LEFT_EN 11
#define LEFT_IN1 6
#define LEFT_IN2 5

#define RIGHT_EN 10
#define RIGHT_IN3 12
#define RIGHT_IN4 13


class Robot {

  private:
    int leftSpeed = 75;
    int rightSpeed = 65;
    int leftTurn = 15;
    int rightTurn = 15;

  public:

    Robot() {
      // Constructor sets nothing because pins are #defined
    }

    void initPins() {
      pinMode(LEFT_IR, INPUT);
      pinMode(RIGHT_IR, INPUT);

      pinMode(LEFT_EN, OUTPUT);
      pinMode(RIGHT_EN, OUTPUT);

      pinMode(LEFT_IN1, OUTPUT);
      pinMode(LEFT_IN2, OUTPUT);
      pinMode(RIGHT_IN3, OUTPUT);
      pinMode(RIGHT_IN4, OUTPUT);
    }

    void update() {

      bool leftBlack = digitalRead(LEFT_IR);
      bool rightBlack = digitalRead(RIGHT_IR);

      Serial.print("L:");
      Serial.print(!leftBlack);
      
      Serial.print(" R:");
      Serial.println(!rightBlack);
      

      // CASE 1: Both white → forward
      if (!leftBlack && !rightBlack) {
        move(leftSpeed, rightSpeed);
      }

      // CASE 2: Both black → forward
      else if (leftBlack && rightBlack) {
        move(leftSpeed, rightSpeed);
      }

      // CASE 3: Left black → turn left
      else if (leftBlack && !rightBlack) {
        move(leftTurn, rightSpeed);
      }

      // CASE 4: Right black → turn right
      else if (!leftBlack && rightBlack) {
        move(leftSpeed, rightTurn);
      }
    }

    void move(int L, int R) {
      analogWrite(LEFT_EN, L);
      analogWrite(RIGHT_EN, R);

      digitalWrite(LEFT_IN1, LOW);
      digitalWrite(LEFT_IN2, HIGH);

      digitalWrite(RIGHT_IN3, HIGH);
      digitalWrite(RIGHT_IN4, LOW);
    }
};


Robot bot;

void setup() {
  Serial.begin(9600);
  bot.initPins();
}

void loop() {
  bot.update();
  delay(32);
}
