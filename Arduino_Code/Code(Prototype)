#define LEFT_IR 3
#define RIGHT_IR 2

#define LEFT_EN 11
#define LEFT_IN1 6
#define LEFT_IN2 5

#define RIGHT_EN 10
#define RIGHT_IN3 12
#define RIGHT_IN4 13

#define LEFT_TRIG  8
#define LEFT_ECHO  9
#define RIGHT_TRIG 4
#define RIGHT_ECHO 7

#define OBSTACLE_DISTANCE_CM 30

int baseLeftSpeed  = 90;
int baseRightSpeed = 92;

float Kp = 20;
float Ki = 0;
float Kd = 12;

int error = 0;
int lastError = 0;
float integral = 0;

enum State {
  FOLLOW_LINE,
  AVOID_OBSTACLE,
  TURN_BACK_180,
  SEARCH_LINE
};

State state = FOLLOW_LINE;

int lastDirection = 1;
int avoidStep = 0;
int turnStep = 0;

int obstacleCount = 0;

unsigned long stepStart = 0;

bool obstacleLocked = false;
int obstacleStableCount = 0;

long getDistance(int trigPin, int echoPin) {
  digitalWrite(trigPin, LOW);
  delayMicroseconds(2);

  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(trigPin, LOW);

  long duration = pulseIn(echoPin, HIGH, 25000);

  if (duration == 0) return 999;

  long distance = duration * 0.034 / 2;

  if (distance < 3) return 999;

  return distance;
}

void setMotor(int leftSpeed, int rightSpeed) {
  leftSpeed = constrain(leftSpeed, -255, 255);
  rightSpeed = constrain(rightSpeed, -255, 255);

  if (leftSpeed >= 0) {
    analogWrite(LEFT_EN, leftSpeed);
    digitalWrite(LEFT_IN1, LOW);
    digitalWrite(LEFT_IN2, HIGH);
  } else {
    analogWrite(LEFT_EN, -leftSpeed);
    digitalWrite(LEFT_IN1, HIGH);
    digitalWrite(LEFT_IN2, LOW);
  }

  if (rightSpeed >= 0) {
    analogWrite(RIGHT_EN, rightSpeed);
    digitalWrite(RIGHT_IN3, HIGH);
    digitalWrite(RIGHT_IN4, LOW);
  } else {
    analogWrite(RIGHT_EN, -rightSpeed);
    digitalWrite(RIGHT_IN3, LOW);
    digitalWrite(RIGHT_IN4, HIGH);
  }
}

void resetPID() {
  integral = 0;
  lastError = 0;
}

void followLinePID(bool leftBlack, bool rightBlack) {
  if (leftBlack && rightBlack) {
    error = 0;
  }
  else if (leftBlack && !rightBlack) {
    error = -1;
    lastDirection = -1;
  }
  else if (!leftBlack && rightBlack) {
    error = 1;
    lastDirection = 1;
  }
  else {
    state = SEARCH_LINE;
    return;
  }

  integral = integral + error;
  integral = constrain(integral, -20, 20);

  int derivative = error - lastError;
  int correction = (Kp * error) + (Ki * integral) + (Kd * derivative);

  lastError = error;

  int leftSpeed  = baseLeftSpeed + correction;
  int rightSpeed = baseRightSpeed - correction;

  leftSpeed = constrain(leftSpeed, 55, 120);
  rightSpeed = constrain(rightSpeed, 55, 120);

  setMotor(leftSpeed, rightSpeed);
}

void setup() {
  pinMode(LEFT_IR, INPUT);
  pinMode(RIGHT_IR, INPUT);

  pinMode(LEFT_EN, OUTPUT);
  pinMode(LEFT_IN1, OUTPUT);
  pinMode(LEFT_IN2, OUTPUT);

  pinMode(RIGHT_EN, OUTPUT);
  pinMode(RIGHT_IN3, OUTPUT);
  pinMode(RIGHT_IN4, OUTPUT);

  pinMode(LEFT_TRIG, OUTPUT);
  pinMode(LEFT_ECHO, INPUT);

  pinMode(RIGHT_TRIG, OUTPUT);
  pinMode(RIGHT_ECHO, INPUT);

  Serial.begin(9600);
}

void loop() {
  bool leftBlack = digitalRead(LEFT_IR);
  bool rightBlack = digitalRead(RIGHT_IR);

  long leftDist = getDistance(LEFT_TRIG, LEFT_ECHO);
  long rightDist = getDistance(RIGHT_TRIG, RIGHT_ECHO);

  bool obstacleRaw =
    (leftDist < OBSTACLE_DISTANCE_CM ||
     rightDist < OBSTACLE_DISTANCE_CM);

  if (!obstacleRaw) {
    obstacleStableCount = 0;
    obstacleLocked = false;
  } else {
    obstacleStableCount++;
  }

  
  // STATE 1: FOLLOW LINE
 

  if (state == FOLLOW_LINE) {

    if (!obstacleLocked && obstacleStableCount >= 3) {

      obstacleCount++;

      Serial.print("Obstacle number: ");
      Serial.println(obstacleCount);

      obstacleLocked = true;
      obstacleStableCount = 0;

      setMotor(0, 0);
      stepStart = millis();

      if (obstacleCount == 1) {
        // First obstacle: normal avoidance
        state = AVOID_OBSTACLE;
        avoidStep = 0;
      }
      else if (obstacleCount == 2) {
        // Second obstacle: 180 degree turn
        state = TURN_BACK_180;
        turnStep = 0;
      }
      else {
        // Third or later obstacle: also turn back
        state = TURN_BACK_180;
        turnStep = 0;
      }

      return;
    }

    followLinePID(leftBlack, rightBlack);
  }

  
  // STATE 2: FIRST OBSTACLE AVOIDANCE
 

  else if (state == AVOID_OBSTACLE) {

    unsigned long t = millis() - stepStart;

    if (avoidStep == 0) {
      setMotor(0, 0);

      if (t > 200) {
        avoidStep = 1;
        stepStart = millis();
      }
    }

    else if (avoidStep == 1) {
      setMotor(80, 30);

      if (t > 450) {
        avoidStep = 2;
        stepStart = millis();
      }
    }

    else if (avoidStep == 2) {
      setMotor(80, 82);

      if (t > 650) {
        avoidStep = 3;
        stepStart = millis();
      }
    }

    else if (avoidStep == 3) {
      setMotor(30, 80);

      if (t > 700) {
        avoidStep = 4;
        stepStart = millis();
      }
    }

    else if (avoidStep == 4) {

      if (leftBlack || rightBlack) {
        state = FOLLOW_LINE;
        obstacleLocked = true;
        obstacleStableCount = 0;
        resetPID();
        return;
      }

      setMotor(80, 82);

      if (t > 3000) {
        state = SEARCH_LINE;
      }
    }
  }

  
  // STATE 3: SECOND OBSTACLE 180 DEGREE TURN
  

  else if (state == TURN_BACK_180) {

    unsigned long t = millis() - stepStart;

    if (turnStep == 0) {
      // Stop before turning
      setMotor(0, 0);

      if (t > 200) {
        turnStep = 1;
        stepStart = millis();
      }
    }

    else if (turnStep == 1) {
      // Spin in place for 180 degree turn
      // If robot does not turn enough, increase 950
      // If robot turns too much, decrease 950
      setMotor(80, -80);

      if (t > 700) {
        turnStep = 2;
        stepStart = millis();
      }
    }

    else if (turnStep == 2) {
      // After turning, find the line again
      if (leftBlack || rightBlack) {
        state = FOLLOW_LINE;
        obstacleLocked = true;
        obstacleStableCount = 0;
        resetPID();
        return;
      }

      // Move slowly until line is found
      setMotor(60, 60);

      if (t > 900) {
        state = SEARCH_LINE;
      }
    }
  }

  
  // STATE 4: SEARCH LINE
 

  else if (state == SEARCH_LINE) {

    if (leftBlack || rightBlack) {
      state = FOLLOW_LINE;
      resetPID();
      return;
    }

    if (lastDirection == 1) {
      setMotor(55, 15);
    } else {
      setMotor(15, 55);
    }
  }
}
